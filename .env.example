# Set to "true" for local development with mock data
# When true, services return mock data instead of calling the backend API
NEXT_PUBLIC_DEV_BYPASS=false

# Backend URL for server-side proxy routes (Next.js API routes → NestJS backend)
# This is NOT exposed to the browser — only used in server-side route handlers
BACKEND_URL=http://localhost:3000

# Must match the backend's JWT_SECRET so token verification works
AUTH_SECRET=change-me-to-match-backend-JWT_SECRET
